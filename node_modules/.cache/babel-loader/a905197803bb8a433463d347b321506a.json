dd-selected-facet=\"addSelectedFacet\"\n          :remove-facet=\"removeFacet\"\n          />\n          </div>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-header\" id=\"headingTwo\">\n          <h5 class=\"mb-0 accordion-header-content\">\n            <span class=\"title-section\">\n              <span class=\"title\">{{facets.WHATList[0].name}}</span>\n              <span class=\"description\">{{facets.WHATList[0].description}}</span>\n            </span>\n            <button class=\"btn btn-link accordion-button\" @click=\"toggleAccordion('two')\" :class=\"{ collapsed: !isOpen.two }\"\n              aria-controls=\"collapseTwo\">\n              <i :class=\"['bi', isOpen.two ? 'bi-chevron-up' : 'bi-chevron-down', 'font-' + facets.WHATList[0].color]\"></i>\n            </button>\n          </h5>\n        </div>\n        <div id=\"collapseTwo\" :class=\"['collapse', { show: isOpen.two }]\" aria-labelledby=\"headingTwo\">\n          <div class=\"card-body\">\n            <FacetCategory\n          :category-items-list=\"facets.WHATList\"\n          :add-selected-facet=\"addSelectedFacet\"\n          :remove-facet=\"removeFacet\"\n        />\n          </div>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-header\" id=\"headingThree\">\n          <h5 class=\"mb-0 accordion-header-content\">\n            <span class=\"title-section\">\n              <span class=\"title\">{{facets.HOWList[0].name}}</span>\n              <span class=\"description\">{{facets.HOWList[0].description}}</span>\n            </span>\n            <button class=\"btn btn-link accordion-button\" @click=\"toggleAccordion('three')\" :class=\"{ collapsed: !isOpen.three }\"\n              aria-controls=\"collapseThree\">\n              <i :class=\"['bi', isOpen.three ? 'bi-chevron-up' : 'bi-chevron-down', 'font-' + facets.HOWList[0].color]\"></i>\n            </button>\n          </h5>\n        </div>\n        <div id=\"collapseThree\" :class=\"['collapse', { show: isOpen.three }]\" aria-labelledby=\"headingThree\">\n          <div class=\"card-body\">\n            <FacetCategory :category-items-list=\"facets.HOWList\" :add-selected-facet=\"addSelectedFacet\"\n              :remove-facet=\"removeFacet\" />\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n// import \"../../basicVueMaterialImports\";\nimport FacetCategory from \"./FacetCategory\";\nimport \"../../style/mainStyles.scss\";\n\nexport default {\n  name: \"FacetedNavigation\",\n  components: { FacetCategory },\n  props: [\"facets\", \"addSelectedFacet\", \"removeFacet\"],\n  data() {\n    return {\n      isOpen: {\n        one: true,\n        two: false,\n        three: false\n      }\n    }\n  },\n  methods: {\n    toggleAccordion(panel) {\n      this.isOpen[panel] = !this.isOpen[panel];\n    },\n   \n    deselectFacets: function () {\n      this.$props.facets.HOWList[1].forEach((group) => {\n        group.elements.forEach((element) => {\n          element.chosen = false;\n          this.$props.removeFacet(element);\n        });\n      });\n\n      this.$props.facets.WHYList[1].forEach((group) => {\n              group.elements.forEach((element) => {\n                element.chosen = false;\n                this.$props.removeFacet(element);\n              });\n            });\n      this.$props.facets.WHATList[1].forEach((group) => {\n        group.elements.forEach((element) => {\n          element.chosen = false;\n          this.$props.removeFacet(element);\n        });\n      });\n    },\n  },\n  computed: {\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n@use \"../../style/mainStyles.scss\" as ms;\n\n\n.card-body {\n    \n    padding: 0.1rem!important;\n  }\n  \n  .btn {\n    width:100%;\n    text-align:left;\n  }\n\n  .accordion-header-content {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    width: 100%;\n    gap: 1rem;\n  }\n\n  .title-section {\n    display: flex;\n    flex-direction: column;\n    flex-grow: 1;\n\n    .title {\n      font-weight: 600;\n      font-size: 1rem;\n      display: block;\n      margin-bottom: 0.25rem;\n    }\n\n    .description {\n      font-size: 0.85rem;\n      font-weight: 400;\n      color: #666;\n      display: block;\n    }\n  }\n\n  .accordion-button {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 0;\n    color: inherit !important;\n    text-decoration: none;\n    transition: all 0.3s ease;\n    padding: 0.25rem 0.5rem !important;\n    font-weight: 500;\n    min-width: fit-content;\n    flex-shrink: 0;\n\n    &:hover {\n      background-color: rgba(0, 0, 0, 0.05);\n      border-radius: 4px;\n    }\n\n    i {\n      font-size: 1.2rem;\n      flex-shrink: 0;\n    }\n  }\n\n  .card-header {\n    background-color: white;\n    border: 1px solid #e0e0e0;\n    padding: 1rem !important;\n\n    h5 {\n      margin-bottom: 0;\n    }\n  }\n\n  .card {\n    border: 1px solid #e0e0e0;\n    border-radius: 4px;\n    margin-bottom: 0.5rem;\n\n    &:last-child {\n      margin-bottom: 0;\n    }\n  }\n\n// .deselect-btn {\n//   z-index: 4;\n//   position: absolute;\n//   top: 12px;\n//   right: 30px;\n\n//   &:hover {\n//     box-shadow: #9f9f9f 0 10px 20px;\n//   }\n// }\n\n</style>\n"]},"metadata":{},"sourceType":"module"}