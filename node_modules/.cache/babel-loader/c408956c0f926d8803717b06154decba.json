{"ast":null,"code":"import { defineComponent, ref, computed } from 'vue';\nimport { createPopper } from '@popperjs/core';\nexport default defineComponent({\n  name: 'TooltipComponent',\n  props: {\n    placement: String,\n    blockname: String,\n    description: String,\n    color: String,\n    disabled: Boolean\n  },\n\n  setup(props) {\n    const button = ref(null);\n    const tooltip = ref(null);\n    const popperInstance = computed(() => {\n      return createPopper(button.value, tooltip.value, {\n        placement: props.placement,\n        blockname: props.blockname,\n        description: props.description,\n        color: props.color,\n        disabled: props.disabled,\n        modifiers: [{\n          name: 'offset',\n          options: {\n            offset: [0, 10]\n          }\n        }],\n        strategy: 'absolute'\n      });\n    });\n\n    const insertElement = (btn, tip) => {\n      button.value = btn;\n      tooltip.value = tip;\n    };\n\n    const handleShow = e => {\n      if (button.value === null && tooltip.value === null) {\n        insertElement(e.target, e.target.parentElement.querySelector('.tooltipText'));\n      }\n\n      tooltip.value.setAttribute('data-show', '');\n      popperInstance.value.update();\n    };\n\n    const handleHide = e => {\n      if (button.value === null && tooltip.value === null) {\n        insertElement(e.target, e.target.parentElement.querySelector('.tooltipText'));\n      }\n\n      tooltip.value.removeAttribute('data-show');\n    };\n\n    return {\n      handleShow,\n      handleHide\n    };\n  }\n\n});","map":{"version":3,"mappings":"AACA,SAASA,eAAT,EAA0BC,GAA1B,EAA+BC,QAA/B,QAA+C,KAA/C;AACA,SAASC,YAAT,QAA6B,gBAA7B;AAEA,eAAeH,eAAe,CAAC;EAC7BI,IAAI,EAAE,kBADuB;EAE7BC,KAAK,EAAE;IACLC,SAAS,EAAEC,MADN;IAELC,SAAS,EAAED,MAFN;IAGLE,WAAW,EAAEF,MAHR;IAILG,KAAK,EAAEH,MAJF;IAKLI,QAAQ,EAAEC;EALL,CAFsB;;EAS7BC,KAAK,CAACR,KAAD,EAAQ;IACX,MAAMS,MAAK,GAAIb,GAAG,CAAC,IAAD,CAAlB;IACA,MAAMc,OAAM,GAAId,GAAG,CAAC,IAAD,CAAnB;IAEA,MAAMe,cAAa,GAAId,QAAQ,CAAC,MAAM;MACpC,OAAOC,YAAY,CAACW,MAAM,CAACG,KAAR,EAAeF,OAAO,CAACE,KAAvB,EAA8B;QAC/CX,SAAS,EAACD,KAAK,CAACC,SAD+B;QAE/CE,SAAS,EAAEH,KAAK,CAACG,SAF8B;QAG/CC,WAAW,EAAEJ,KAAK,CAACI,WAH4B;QAI/CC,KAAK,EAAEL,KAAK,CAACK,KAJkC;QAK/CC,QAAQ,EAAEN,KAAK,CAACM,QAL+B;QAM/CO,SAAS,EAAE,CACT;UACEd,IAAI,EAAE,QADR;UAEEe,OAAO,EAAE;YACPC,MAAM,EAAE,CAAC,CAAD,EAAI,EAAJ;UADD;QAFX,CADS,CANoC;QAc/CC,QAAQ,EAAE;MAdqC,CAA9B,CAAnB;IAgBD,CAjB8B,CAA/B;;IAmBA,MAAMC,aAAY,GAAI,CAACC,GAAD,EAAMC,GAAN,KAAc;MAClCV,MAAM,CAACG,KAAP,GAAeM,GAAf;MACAR,OAAO,CAACE,KAAR,GAAgBO,GAAhB;IACF,CAHA;;IAKA,MAAMC,UAAS,GAAKC,CAAD,IAAO;MACxB,IAAIZ,MAAM,CAACG,KAAP,KAAiB,IAAjB,IAAyBF,OAAO,CAACE,KAAR,KAAkB,IAA/C,EAAqD;QACnDK,aAAa,CAACI,CAAC,CAACC,MAAH,EAAWD,CAAC,CAACC,MAAF,CAASC,aAAT,CAAuBC,aAAvB,CAAqC,cAArC,CAAX,CAAb;MACF;;MACAd,OAAO,CAACE,KAAR,CAAca,YAAd,CAA2B,WAA3B,EAAwC,EAAxC;MACAd,cAAc,CAACC,KAAf,CAAqBc,MAArB;IACF,CANA;;IAQA,MAAMC,UAAS,GAAKN,CAAD,IAAO;MACxB,IAAIZ,MAAM,CAACG,KAAP,KAAiB,IAAjB,IAAyBF,OAAO,CAACE,KAAR,KAAkB,IAA/C,EAAqD;QACnDK,aAAa,CAACI,CAAC,CAACC,MAAH,EAAWD,CAAC,CAACC,MAAF,CAASC,aAAT,CAAuBC,aAAvB,CAAqC,cAArC,CAAX,CAAb;MACF;;MACAd,OAAO,CAACE,KAAR,CAAcgB,eAAd,CAA8B,WAA9B;IACF,CALA;;IAOA,OAAO;MACLR,UADK;MAELO;IAFK,CAAP;EAIF;;AAxD6B,CAAD,CAA9B","names":["defineComponent","ref","computed","createPopper","name","props","placement","String","blockname","description","color","disabled","Boolean","setup","button","tooltip","popperInstance","value","modifiers","options","offset","strategy","insertElement","btn","tip","handleShow","e","target","parentElement","querySelector","setAttribute","update","handleHide","removeAttribute"],"sourceRoot":"","sources":["/Users/mkeck/Documents/GitHub/explorationtool/src/components/helpers/Tooltip.vue"],"sourcesContent":["<script>\nimport { defineComponent, ref, computed } from 'vue'\nimport { createPopper } from '@popperjs/core'\n\nexport default defineComponent({\n  name: 'TooltipComponent',\n  props: {\n    placement: String,\n    blockname: String,\n    description: String,\n    color: String,\n    disabled: Boolean\n  },\n  setup(props) {\n    const button = ref(null)\n    const tooltip = ref(null)\n\n    const popperInstance = computed(() => {\n      return createPopper(button.value, tooltip.value, {\n        placement:props.placement,\n        blockname: props.blockname,\n        description: props.description,\n        color: props.color,\n        disabled: props.disabled,\n        modifiers: [\n          {\n            name: 'offset',\n            options: {\n              offset: [0, 10],\n            },\n          },\n        ],\n        strategy: 'absolute'\n      })\n    });\n\n    const insertElement = (btn, tip) => {\n      button.value = btn\n      tooltip.value = tip\n    }\n\n    const handleShow = (e) => {\n      if (button.value === null && tooltip.value === null) {\n        insertElement(e.target, e.target.parentElement.querySelector('.tooltipText'))\n      }\n      tooltip.value.setAttribute('data-show', '')\n      popperInstance.value.update()\n    }\n\n    const handleHide = (e) => {\n      if (button.value === null && tooltip.value === null) {\n        insertElement(e.target, e.target.parentElement.querySelector('.tooltipText'))\n      }\n      tooltip.value.removeAttribute('data-show')\n    }\n\n    return {\n      handleShow,\n      handleHide\n    }\n  }\n})\n</script>\n  \n<template>\n  <div class=\"tooltip\">\n\n    <span :class=\"[!disabled ? color : '']\" class=\"badge badge-dark\" type=\"button\" aria-describedby=\"tooltip\"\n      @mouseenter=\"handleShow($event)\" @mouseleave=\"handleHide($event)\" @focus=\"handleShow($event)\"\n      @blur=\"handleHide($event)\">\n      {{ blockname }}\n    </span>\n\n    <div v-if=\"description != ''\" class=\"tooltipText\" role=\"tooltip\">\n      {{ description }}\n      <div class=\"tooltipArrow\" data-popper-arrow></div>\n    </div>\n\n  </div>\n</template>\n  \n<style lang=\"scss\" scoped>\n.badge {\n  z-index: 5;\n}\n\n.tooltip {\n  z-index: 100;\n  opacity: 10;\n  position: relative;\n  .tooltipText {\n    width:10rem!important;\n\n    z-index: 110;\n    background-color: #333;\n    color: white;\n    padding: 5px 6px;\n    border-radius: 4px;\n    font-size: 8px;\n    display: none;\n    opacity: 100;\n  }\n  .tooltipText[data-show] {\n    display: block;\n  }\n\n  .tooltipArrow,\n  .tooltipArrow::before {\n    position: absolute;\n    width: 8px;\n    height: 8px;\n    background: inherit;\n  }\n\n  .tooltipArrow {\n    visibility: hidden;\n  }\n\n  .tooltipArrow::before {\n    visibility: visible;\n    content: '';\n    transform: rotate(45deg);\n  }\n\n  .tooltipText[data-popper-placement^='top']>.tooltipArrow {\n    bottom: -4px;\n  }\n\n  .tooltipText[data-popper-placement^='bottom']>.tooltipArrow {\n    top: -4px;\n  }\n\n  .tooltipText[data-popper-placement^='left']>.tooltipArrow {\n    right: -4px;\n  }\n\n  .tooltipText[data-popper-placement^='right']>.tooltipArrow {\n    left: -4px;\n  }\n}\n</style>\n  "]},"metadata":{},"sourceType":"module"}