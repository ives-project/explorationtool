{"ast":null,"code":"import FacetItem from \"./../facetNavigation/FacetItem\";\nexport default {\n  data: () => ({\n    toggled: [],\n    currentblock: null\n  }),\n  name: \"DetailElement\",\n  components: {\n    FacetItem\n  },\n  props: [\"pattern\", \"description\", \"userstudy\"],\n  methods: {\n    getBlocksPerItems(item) {\n      let blockArray = [];\n      item.blocks.forEach(block => {\n        blockArray.push(this.$patternService.getBlockByUid(block));\n      });\n      return blockArray;\n    },\n\n    getBlockByUid(uid) {\n      let block = this.$patternService.getBlockByUid(uid);\n      this.currentblock = block;\n      return block;\n    },\n\n    isActive(item) {\n      return this.toggled.indexOf(item) >= 0;\n    },\n\n    toggleItem(item) {\n      const index = this.toggled.indexOf(item);\n      console.log(index);\n\n      if (index >= 0) {\n        this.toggled.splice(index, 1);\n        return;\n      }\n\n      this.toggled.push(item);\n    },\n\n    getImgSrc(src) {\n      try {\n        return require(`@/assets/resources/patterns/${src}`);\n      } catch (_) {\n        console.error('Img at path ' + src + ' was not found');\n        return require('@/assets/resources/patterns/dummy.png');\n      }\n    }\n\n  }\n};","map":{"version":3,"mappings":"AAiMA,OAAOA,SAAP,MAAsB,gCAAtB;AAEA,eAAe;EACbC,IAAI,EAAE,OAAO;IACPC,OAAO,EAAE,EADF;IAEPC,YAAY,EAAE;EAFP,CAAP,CADO;EAMbC,IAAI,EAAE,eANO;EAObC,UAAU,EAAE;IAAEL;EAAF,CAPC;EAQbM,KAAK,EAAE,CAAC,SAAD,EAAY,aAAZ,EAA2B,WAA3B,CARM;EAUbC,OAAO,EAAE;IACPC,iBAAiB,CAACC,IAAD,EAAM;MACrB,IAAIC,UAAS,GAAI,EAAjB;MACAD,IAAI,CAACE,MAAL,CAAYC,OAAZ,CAAqBC,KAAD,IAAW;QAC7BH,UAAU,CAACI,IAAX,CAAgB,KAAKC,eAAL,CAAqBC,aAArB,CAAmCH,KAAnC,CAAhB;MACD,CAFD;MAGA,OAAOH,UAAP;IACD,CAPM;;IAQPM,aAAa,CAACC,GAAD,EAAM;MACjB,IAAIJ,KAAI,GAAI,KAAKE,eAAL,CAAqBC,aAArB,CAAmCC,GAAnC,CAAZ;MACA,KAAKd,YAAL,GAAkBU,KAAlB;MACA,OAAOA,KAAP;IACD,CAZM;;IAaPK,QAAO,CAAGT,IAAH,EAAS;MACZ,OAAO,KAAKP,OAAL,CAAaiB,OAAb,CAAqBV,IAArB,KAA8B,CAArC;IACH,CAfM;;IAgBPW,UAAS,CAAGX,IAAH,EAAS;MAChB,MAAMY,KAAI,GAAI,KAAKnB,OAAL,CAAaiB,OAAb,CAAqBV,IAArB,CAAd;MACAa,OAAO,CAACC,GAAR,CAAYF,KAAZ;;MACA,IAAIA,KAAI,IAAK,CAAb,EAAgB;QACd,KAAKnB,OAAL,CAAasB,MAAb,CAAoBH,KAApB,EAA2B,CAA3B;QACA;MACF;;MACA,KAAKnB,OAAL,CAAaY,IAAb,CAAkBL,IAAlB;IACD,CAxBM;;IAyBPgB,SAAS,CAACC,GAAD,EAAK;MACZ,IAAG;QACD,OAAOC,OAAO,CAAE,+BAA8BD,GAAI,EAApC,CAAd;MACD,CAFD,CAEC,OAAME,CAAN,EAAQ;QACPN,OAAO,CAACO,KAAR,CAAc,iBAAeH,GAAf,GAAmB,gBAAjC;QAEA,OAAOC,OAAO,CAAC,uCAAD,CAAd;MACF;IACD;;EAjCM;AAVI,CAAf","names":["FacetItem","data","toggled","currentblock","name","components","props","methods","getBlocksPerItems","item","blockArray","blocks","forEach","block","push","$patternService","getBlockByUid","uid","isActive","indexOf","toggleItem","index","console","log","splice","getImgSrc","src","require","_","error"],"sourceRoot":"","sources":["/Users/mkeck/Documents/GitHub/IVES2/src/components/detailView/DetailElement.vue"],"sourcesContent":["<template>\n\n  <div id=\"accordion-element\">\n    <div class=\"card\">\n      \n      <div class=\"card-header\" :id=\"'collapse_' + pattern.uid+pattern.nr\" >\n          <button class=\"btn btn-link header-box\" :aria-controls=\"pattern.uid\" \n              v-bind:href=\"'#collapse'\" \n              v-on:click=\"toggleItem(pattern)\"\n              data-toggle=\"collapse\" \n              :data-target=\"'#' + pattern.uid+pattern.nr\" \n              aria-expanded=\"true\">\n              \n\n              <span class=\"title\" \n                :class=\"{ active: isActive(pattern) }\">\n                <img         \n                  :src=\"getImgSrc( pattern.imageName)\"\n                  :alt=\"pattern.title\"\n                  :title=\"pattern.title\"\n                  class=\"vorschau-img\"\n                  />\n\n                {{ pattern.nr }} \n                {{ pattern.title }}\n              </span>\n              <i \n                  :class=\"[isActive(pattern) ? 'bi-chevron-up': 'bi-chevron-down' ]\"\n                  class=\"bi\"></i>\n          </button>\n      </div>\n\n      <div :id=\"pattern.uid+pattern.nr\" class=\"collapse\" :aria-labelledby=\"'collapse_' + pattern.uid+pattern.nr\" data-parent=\"#accordion-element\">\n        <div class=\"card-body\">\n\n          <!--IMG-->\n          <!-- <div class=\"col-12 img-element\">\n          \n            <img         \n              :src=\"getImgSrc( pattern.imageName)\"\n              :alt=\"pattern.title\"\n              :title=\"pattern.title\"\n              :class=\"pattern.imageBlur\"/>\n          </div>\n\n          <br/> -->\n\n    \n          <!--DESCRIPTION-->\n          <div v-for=\"(item, index) in pattern.details\" :key=\"item.id\">\n\n            <div v-if=\"index === 'description'\" :item=\"item\">\n              <div class=\"title-small\">Description</div>\n              {{ item }}\n            </div>\n          </div>\n\n          \n          <!--DETAILS-->\n          <div v-for=\"(item, index) in pattern.details\" :key=\"item.id\">\n            <div v-if=\"index !== 'description' && item !== ''\" :item=\"item\">\n              <hr />\n              <div v-if=\"index=='userstudy'\" class=\"title-small\">User Study</div>\n              <div v-else class=\"title-small\">{{ index }}</div>\n              {{ item }}\n            </div>\n          </div>\n\n          <!--PATTERNS-->\n          <div v-for=\"(item, index) in pattern.pattern\" :key=\"item.id\">\n            <div v-if=\"index === 0\">\n              <hr />\n              <span class=\"title-small\">Patterns</span>\n            </div>\n\n            <div class=\"card bg-light \" style=\"max-width: 100%\">\n              <div class=\"card-header\">{{ item.title }}</div>\n              <div class=\"card-body\">\n                <div class=\"row\">\n                  <div class=\"img-element col-8\">\n                    <img \n                      :src=\"getImgSrc(item.image)\"\n                      :alt=\"pattern.title\"\n                      :title=\"pattern.title\"\n                      />\n                      <!-- :class=\"pattern.imageBlur\" -->\n                    </div>\n                    <div class=\"col-4 legend\">\n                      {{ item.description }}\n                    </div>\n                  <!--blocks-->\n                  <div class=\"col-auto\">\n                      <div class=\"row\">\n                        <ul class=\"why-group\">\n                          \n                          <li>\n                            <span v-for=\"currentBlock in getBlocksPerItems(item)\" :key=\"currentBlock\">\n                              <span v-if=\"currentBlock\" class=\"block-list\">\n                                  <span v-if=\" (currentBlock.facet==`recommenderSystemIssue` || currentBlock.facet==`systemOrUserIntent`)\">\n                                    <FacetItem \n                                        :block=\"currentBlock\"\n                                        :description=\"currentBlock.description\"\n                                        detailElement=true\n                                        /> \n                                  </span>\n                                </span>\n                              </span>\n                          </li>\n                        </ul>\n\n                        <ul class=\"what-group\">\n\n                          <li >\n\n                            <span v-for=\"currentBlock in getBlocksPerItems(item)\" :key=\"currentBlock\">\n                              <span v-if=\"currentBlock\" class=\"block-list\">\n                                  <span v-if=\"(currentBlock.facet==`dataDomain` || currentBlock.facet == `contextInformation`)\">\n                                    <FacetItem \n                                        :block=\"currentBlock\"\n                                        :description=\"currentBlock.description\"\n                                        detailElement=true\n                                        /> \n                                  </span>\n                                </span>\n                              </span>\n                          </li>\n                        </ul>\n                        <ul class=\"how-group\">\n                          <li>\n                            <span v-for=\"currentBlock in getBlocksPerItems(item)\" :key=\"currentBlock\">\n                              <span v-if=\"currentBlock\" class=\"block-list\">\n                                  \n                                    <span v-if=\"(currentBlock.facet==`visualizationTechnique` || currentBlock.facet==`visualElement` || currentBlock.facet==`view` || currentBlock.facet==`visualChannel` || currentBlock.facet==`interaction`)\" >\n\n                                    <FacetItem \n                                        :block=\"currentBlock\"\n                                        :description=\"currentBlock.description\"\n                                        detailElement=true\n                                        /> \n                                  </span>\n                                </span>\n                              </span>\n                          </li>\n\n                         \n                        </ul>\n\n                       \n\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <br/>\n          </div>\n\n           <!--LITERATURE-->\n           <div v-for=\"(item, index) in pattern.literature\" :key=\"item.id\" :citication=\"item.citication\">\n            <span v-if=\"index === 'citication'\" :item=\"item\">\n              \n              {{ item }}\n            </span>\n          </div>  \n        \n          <!--RESOURCES-->\n          <span v-for=\"(resource, index)  in pattern.resources\" :key=\"resource\">\n            <div v-if=\"resource && index === 0\" class=\"title-small\"><hr />Resources</div>\n            <span v-if=\"resource.type === 'Paper'\" class=\"ressource\">\n              <a target=\"_blank\" class=\"btn btn-primary\" :href=\"resource.url\" :alt=\"resource.title\" :title=\"resource.title\">\n                <i class=\"bi bi-file-earmark\"></i>\n              </a>\n            </span>\n            <span  v-else-if=\"resource.type === 'Youtube'\" class=\"ressource\">\n              <a target=\"_blank\" class=\"btn btn-primary\" :href=\"resource.url\" :alt=\"resource.title\" :title=\"resource.title\">\n                <i class=\"bi bi-youtube\"></i>\n              </a>\n            </span>\n            <span v-else class=\"ressource\">\n              <a target=\"_blank\" class=\"btn btn-primary\" :href=\"resource.url\" :alt=\"resource.title\" :title=\"resource.title\">\n                <i class=\"bi bi-box-arrow-up-right\"></i>\n              </a>\n            </span>\n          </span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n\n</template>\n\n<script>\nimport FacetItem from \"./../facetNavigation/FacetItem\";\n\nexport default {\n  data: () => ({\n        toggled: [],\n        currentblock: null\n    }),\n    \n  name: \"DetailElement\",\n  components: { FacetItem },\n  props: [\"pattern\", \"description\", \"userstudy\"],\n \n  methods: {\n    getBlocksPerItems(item){\n      let blockArray = [];\n      item.blocks.forEach((block) => {\n        blockArray.push(this.$patternService.getBlockByUid(block))\n      });\n      return blockArray;\n    },\n    getBlockByUid(uid) {\n      let block = this.$patternService.getBlockByUid(uid);\n      this.currentblock=block;\n      return block;\n    },\n    isActive (item) {\n        return this.toggled.indexOf(item) >= 0\n    },\n    toggleItem (item) {\n      const index = this.toggled.indexOf(item);\n      console.log(index);\n      if (index >= 0) {\n        this.toggled.splice(index, 1)\n        return\n      }\n      this.toggled.push(item);\n    },\n    getImgSrc(src){\n      try{ \n        return require(`@/assets/resources/patterns/${src}`)\n      }catch(_){\n        console.error('Img at path '+src+' was not found');\n        \n        return require('@/assets/resources/patterns/dummy.png');\n      }\n    },\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n@use \"../../style/mainStyles.scss\" as ms;\n\n.vorschau-img {\n  width: 50px; \n  height: 50px; \n  object-fit: cover;\n  margin-right:14px;\n}\n.pattern-block {\n  width:85px;\n}\n.my-card-pattern {\n  border:none;\n }\n button.btn.btn-link.header-box {\n    text-align: inherit;\n}\n.header-box\n  {\n    width:100%;\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    \n    i {\n      transition: .3s transform ease-in-out;\n      align-self: center;\n    }\n  }\n.meta-box {\n    width:100%;\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n}\n.img-element img {\n  max-width: 100%;\n  max-height: 100%;\n}\n\n.ressource  {\n  margin-right:3px;\n  > a > i {\n    color:#fff;\n    width: 20px;\n  }\n}\n.active { //active accordeon tab\n  color:ms.$active!important;\n  color: WHITE;\n  border-radius: 100%;\n    \n\n  * i {\n    color:#fff !important;;\n  }\n}\n.literature {\n  font-size:10px;\n}\n.block-list {\n  float: left;\n  margin:0;\n  padding:0;\n}\n.why-group::before {\n  content: \"WHY\";\n}\n.what-group::before {\n  content: \"WHAT\";\n}\n.how-group::before {\n  content: \"HOW\";\n}\n\nul {\n  list-style: none;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}