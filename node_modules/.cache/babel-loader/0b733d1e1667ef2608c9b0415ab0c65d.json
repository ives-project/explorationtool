 :add-selected-facet=\"addSelectedFacet\"\n          :remove-facet=\"removeFacet\"\n          />\n          </div>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-header\" id=\"headingTwo\">\n          <h5 class=\"mb-0\">\n            <button class=\"btn btn-link accordion-button\" \n              @click=\"toggleAccordion('what')\"\n              :aria-expanded=\"accordionOpen.what\"\n              aria-controls=\"collapseTwo\">\n              <span class=\"title\">{{facets.WHATList[0].name}}</span>\n              <br/>\n              <span class=\"description\">{{facets.WHATList[0].description}}</span>\n              <i class=\"bi accordion-arrow\" :class=\"accordionOpen.what ? 'bi-chevron-up' : 'bi-chevron-down'\"></i>\n            </button>\n          </h5>\n        </div>\n        <div id=\"collapseTwo\" class=\"collapse\" :class=\"{ show: accordionOpen.what }\" aria-labelledby=\"headingTwo\">\n          <div class=\"card-body\">\n            <FacetCategory\n          :category-items-list=\"facets.WHATList\"\n          :add-selected-facet=\"addSelectedFacet\"\n          :remove-facet=\"removeFacet\"\n        />\n          </div>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-header\" id=\"headingThree\">\n          <h5 class=\"mb-0\">\n            <button class=\"btn btn-link accordion-button\" \n              @click=\"toggleAccordion('how')\"\n              :aria-expanded=\"accordionOpen.how\"\n              aria-controls=\"collapseThree\">\n              <span class=\"accordion-icon\" :class=\"facets.HOWList[0].color\"></span>\n              <div class=\"accordion-title-wrapper\">\n                <span class=\"title\">{{facets.HOWList[0].name}}</span>\n                <br/>\n                <span class=\"description\">{{facets.HOWList[0].description}}</span>\n              </div>\n              <i class=\"bi accordion-arrow\" :class=\"accordionOpen.how ? 'bi-chevron-up' : 'bi-chevron-down'\"></i>\n            </button>\n          </h5>\n        </div>\n        <div id=\"collapseThree\" class=\"collapse\" :class=\"{ show: accordionOpen.how }\" aria-labelledby=\"headingThree\">\n          <div class=\"card-body\">\n            <FacetCategory :category-items-list=\"facets.HOWList\" :add-selected-facet=\"addSelectedFacet\"\n              :remove-facet=\"removeFacet\" />\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n// import \"../../basicVueMaterialImports\";\nimport FacetCategory from \"./FacetCategory\";\nimport \"../../style/mainStyles.scss\";\n\nexport default {\n  name: \"FacetedNavigation\",\n  components: { FacetCategory },\n  props: [\"facets\", \"addSelectedFacet\", \"removeFacet\"],\n  data() {\n    return {\n      accordionOpen: {\n        why: true,\n        what: false,\n        how: false\n      }\n    };\n  },\n  methods: {\n    toggleAccordion(section) {\n      this.accordionOpen[section] = !this.accordionOpen[section];\n    },\n   \n    deselectFacets: function () {\n      this.$props.facets.HOWList[1].forEach((group) => {\n        group.elements.forEach((element) => {\n          element.chosen = false;\n          this.$props.removeFacet(element);\n        });\n      });\n\n      this.$props.facets.WHYList[1].forEach((group) => {\n              group.elements.forEach((element) => {\n                element.chosen = false;\n                this.$props.removeFacet(element);\n              });\n            });\n      this.$props.facets.WHATList[1].forEach((group) => {\n        group.elements.forEach((element) => {\n          element.chosen = false;\n          this.$props.removeFacet(element);\n        });\n      });\n    },\n  },\n  computed: {\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n@use \"../../style/mainStyles.scss\" as ms;\n\n.card-body {\n    \n    padding: 0.1rem!important;\n  }\n  \n  .btn {\n    width:100%;\n    text-align:left;\n  }\n\n  .accordion-button {\n    display: flex;\n    align-items: flex-start;\n    padding: 0.75rem 1rem;\n    gap: 0.75rem;\n    \n    &:focus {\n      box-shadow: none;\n    }\n  }\n\n  .accordion-icon {\n    width: 2rem;\n    height: 2rem;\n    min-width: 2rem;\n    border-radius: 4px;\n    display: inline-block;\n    flex-shrink: 0;\n  }\n\n  .accordion-title-wrapper {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .title {\n    font-weight: bold;\n    font-size: 1rem;\n    display: block;\n  }\n\n  .description {\n    font-size: 0.85rem;\n    color: #666;\n    display: block;\n  }\n\n  .accordion-arrow {\n    flex-shrink: 0;\n    margin-left: auto;\n    font-size: 1.2rem;\n    margin-top: 0.25rem;\n  }\n\n// .deselect-btn {\n//   z-index: 4;\n//   position: absolute;\n//   top: 12px;\n//   right: 30px;\n\n//   &:hover {\n//     box-shadow: #9f9f9f 0 10px 20px;\n//   }\n// }\n\n</style>\n"]},"metadata":{},"sourceType":"module"}