{"ast":null,"code":"import BaseView from './components/BaseView.vue';\nimport AnalyzePage from './components/AnalyzePage.vue';\nimport HeatmapVueSystem from './components/HeatmapVue.vue';\nimport AboutPage from './components/AboutPage.vue';\nimport NotFound from './components/NotFound.vue';\nimport SearchView from './components/helpers/SearchView.vue';\nimport TermsAndConditions from './components/TermsAndConditions.vue';\nconst routes = {\n  '/': BaseView,\n  '/analyze': AnalyzePage,\n  '/heatmapsystem': HeatmapVueSystem,\n  '/about': AboutPage,\n  '/terms': TermsAndConditions\n};\nexport default {\n  name: 'App',\n  components: {\n    BaseView,\n    AnalyzePage,\n    AboutPage,\n    NotFound,\n    TermsAndConditions,\n    SearchView,\n    HeatmapVueSystem\n  },\n\n  data() {\n    return {\n      currentPath: window.location.hash\n    };\n  },\n\n  computed: {\n    currentView() {\n      return routes[this.currentPath.slice(1) || '/'] || NotFound;\n    }\n\n  },\n\n  mounted() {\n    document.title = \"IVES Project\";\n    window.addEventListener('hashchange', () => {\n      this.currentPath = window.location.hash;\n    });\n  }\n\n};","map":{"version":3,"mappings":"AAwDA,OAAOA,QAAP,MAAqB,2BAArB;AACA,OAAOC,WAAP,MAAwB,8BAAxB;AACA,OAAOC,gBAAP,MAA6B,6BAA7B;AAEA,OAAOC,SAAP,MAAsB,4BAAtB;AACA,OAAOC,QAAP,MAAqB,2BAArB;AACA,OAAOC,UAAP,MAAuB,qCAAvB;AACA,OAAOC,kBAAP,MAA+B,qCAA/B;AAEA,MAAMC,MAAK,GAAI;EACb,KAAKP,QADQ;EAEb,YAAYC,WAFC;EAGb,kBAAkBC,gBAHL;EAIb,UAAUC,SAJG;EAKb,UAAWG;AALE,CAAf;AAQA,eAAe;EACbE,IAAI,EAAE,KADO;EAEbC,UAAU,EAAE;IACVT,QADU;IACAC,WADA;IACaE,SADb;IACwBC,QADxB;IACkCE,kBADlC;IACsDD,UADtD;IACkEH;EADlE,CAFC;;EAKZQ,IAAI,GAAG;IACN,OAAO;MACLC,WAAW,EAAEC,MAAM,CAACC,QAAP,CAAgBC;IADxB,CAAP;EAGD,CATY;;EAUbC,QAAQ,EAAE;IACRC,WAAW,GAAG;MACZ,OAAOT,MAAM,CAAC,KAAKI,WAAL,CAAiBM,KAAjB,CAAuB,CAAvB,KAA6B,GAA9B,CAAN,IAA4Cb,QAAnD;IACF;;EAHQ,CAVG;;EAebc,OAAO,GAAG;IACRC,QAAQ,CAACC,KAAT,GAAiB,cAAjB;IACAR,MAAM,CAACS,gBAAP,CAAwB,YAAxB,EAAsC,MAAM;MAAE,KAAKV,WAAL,GAAmBC,MAAM,CAACC,QAAP,CAAgBC,IAAnC;IAAyC,CAAvF;EACF;;AAlBa,CAAf","names":["BaseView","AnalyzePage","HeatmapVueSystem","AboutPage","NotFound","SearchView","TermsAndConditions","routes","name","components","data","currentPath","window","location","hash","computed","currentView","slice","mounted","document","title","addEventListener"],"sourceRoot":"","sources":["/Users/mkeck/Documents/GitHub/explorationtool/src/App.vue"],"sourcesContent":["<template>\n\n\n\n  <div class=\"container-fluid\" id=\"base\">\n    \n      <div  id=\"header\" class=\"row align-items-center justify-content-center\">\n        <div id=\"logo\" class=\"col-sm\">\n          <a href=\"#\">\n            <img alt=\"Vue logo\" src=\"./assets/resources/Logo-02.png\" >\n          </a>\n        </div>\n        <div class=\"col-sm\">\n           <nav class=\"nav\">\n            <a class=\"nav-link\" href=\"#\">Browse</a>\n            <a class=\"nav-link\" href=\"#/heatmapsystem\">Heatmap</a>\n            <!-- <a class=\"nav-link\" href=\"#/heatmappattern\">Pattern</a> -->\n\n            <a class=\"nav-link\" href=\"#/analyze\">Analyze</a>\n            <a class=\"nav-link\" href=\"#/about\">About</a>\n          </nav>\n        </div>\n        <div class=\"col-sm\">\n          <div class=\"input-group mb-3\">\n            <!-- <SearchView /> -->\n\n          </div>\n         \n        </div>\n      </div>\n    \n\n\n    <div class=\"main\">\n       <component :is=\"currentView\" />\n    </div>\n   </div>\n\n   <div id=\"footer\" class=\"d-flex align-items-center justify-content-center\">\n      <!-- Copyright -->\n      <div class=\"text-center p-3\" style=\"color:white;\">\n        © 2023 IVES Project Team\n      </div>\n      <!-- Copyright -->\n\n      <div class=\"row\">\n        <div class=\"col\"><a href=\"#/terms\"> Terms & Conditions</a></div>\n      </div>\n   </div>\n\n   \n</template>\n\n\n\n<script>\nimport BaseView from './components/BaseView.vue'\nimport AnalyzePage from './components/AnalyzePage.vue'\nimport HeatmapVueSystem from './components/HeatmapVue.vue'\n\nimport AboutPage from './components/AboutPage.vue'\nimport NotFound from './components/NotFound.vue'\nimport SearchView from './components/helpers/SearchView.vue'\nimport TermsAndConditions from './components/TermsAndConditions.vue'\n\nconst routes = {\n  '/': BaseView,\n  '/analyze': AnalyzePage,\n  '/heatmapsystem': HeatmapVueSystem,\n  '/about': AboutPage,\n  '/terms' : TermsAndConditions\n}\n\nexport default {\n  name: 'App',\n  components: {\n    BaseView, AnalyzePage, AboutPage, NotFound, TermsAndConditions, SearchView, HeatmapVueSystem\n  },\n   data() {\n    return {\n      currentPath: window.location.hash\n    }\n  },\n  computed: {\n    currentView() {\n      return routes[this.currentPath.slice(1) || '/'] || NotFound\n    }\n  },\n  mounted() {\n    document.title = \"IVES Project\";\n    window.addEventListener('hashchange', () => { this.currentPath = window.location.hash })\n  }\n}\n</script>\n\n<style>\n@import url(\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css\");\n\n</style>\n\n<style lang=\"scss\" src=\"./style/mainStyles.scss\"></style>\n<style lang=\"scss\" src=\"./assets/resources/font/fonts.scss\"></style><!--font lokal einbinden-->\n\n<style>\n.container-fluid {\n  max-width: 1275px;\n}\nhtml {\n  overflow: auto;\n}\n* {\n  font-family: 'Outfit', sans-serif; \n}\n#logo img {\n   height:9vh;\n}\n#header {\n  height:15vh;\n}\n#footer {\n  margin-top:2vh;\n  height: 9rem;\n  background-color: black;\n  background-image: linear-gradient(to right, #434343 0%, black 100%);\n \n}\n#footer .row div {\n  color:white;\n}\n#base {\n  display: flex;\n  min-height: 84vh;\n  flex-direction: column;\n  justify-content: start;\n}\nnav a:active, nav a:focus, nav a:hover {\n    border-bottom: 2px solid black;\n}\nnav a:focus, nav a.router-link-active, nav a.router-link-exact-active {\n    cursor: pointer;\n    color: black!important;\n}\n\n#nav-menu {\n  font-weight:600;\n}\n#nav-menu a:hover,\n#nav-menu a:active\n {\nborder-bottom: 2px solid #20c997;\n}\n#nav-menu a:focus {\n  border-bottom: 2px solid #20c997;\n\n}\n#nav-menu a:focus,\n nav a.router-link-active,\n nav a.router-link-exact-active {\n   cursor: pointer;\n   color: #20c997!important;\n\n }\n\n#nav-menu a {\n  color: black;\n  text-decoration: none;\n  font-size: 1.2em;\n  text-transform: uppercase;\n  font-weight: 500;\n  -webkit-transition: all 0.2s ease-in-out;\n  transition: all 0.2s ease-in-out;\n}\n\n\n\n#nav-menu .dot {\n  width: 6px;\n  height: 6px;\n  background: #fddb3a;\n  border-radius: 50%;\n  opacity: 0;\n  -webkit-transform: translateX(30px);\n  transform: translateX(30px);\n  -webkit-transition: all 0.2s ease-in-out;\n  transition: all 0.2s ease-in-out;\n}\n\n#nav-menu a:nth-child(1):hover ~ .dot {\n  -webkit-transform: translateX(30px);\n  transform: translateX(30px);\n  -webkit-transition: all 0.2s ease-in-out;\n  transition: all 0.2s ease-in-out;\n  opacity: 1;\n}\n\n#nav-menu a:nth-child(2):hover ~ .dot {\n  -webkit-transform: translateX(110px);\n  transform: translateX(110px);\n  -webkit-transition: all 0.2s ease-in-out;\n  transition: all 0.2s ease-in-out;\n  opacity: 1;\n}\n\n</style>\n\n\n"]},"metadata":{},"sourceType":"module"}